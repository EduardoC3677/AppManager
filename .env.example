# Debug Signing Configuration
# Copy this file to .env and fill in your debug keystore credentials
# DO NOT commit .env file to version control!

# Debug keystore password
DEBUG_STORE_PASSWORD=your_debug_store_password_here

# Debug key password
DEBUG_KEY_PASSWORD=your_debug_key_password_here

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual credentials
# 3. Source the file before building: source .env
# 4. Or export the variables: export DEBUG_STORE_PASSWORD=your_password
