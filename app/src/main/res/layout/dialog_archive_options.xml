<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Storage Estimate -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/m3_sys_color_light_secondary_container"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <TextView
            android:id="@+id/storage_estimate_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/m3_sys_color_light_on_secondary_container"
            android:text="📦 Archive 15 apps • Free up 245 MB" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Cache Clean Option -->
    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cache_clean_checkbox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/clear_cache_before_archive"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        app:buttonIcon="@drawable/ic_cache"
        app:buttonIconTint="@color/m3_sys_color_light_primary" />

    <!-- Data Clean Option -->
    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/data_clean_checkbox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/clear_data_before_archive"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        app:buttonIcon="@drawable/ic_data_usage"
        app:buttonIconTint="@color/m3_sys_color_light_error" />

    <!-- Warning Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/archive_warning"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="@color/m3_sys_color_light_on_surface_variant" />

</LinearLayout>
