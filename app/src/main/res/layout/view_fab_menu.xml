<!-- Material 3 Expressive FAB Menu Layout -->
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Menu Container (hidden by default) -->
    <LinearLayout
        android:id="@+id/menu_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="72dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:elevation="8dp">

        <!-- Menu items will be added programmatically -->

    </LinearLayout>

    <!-- Close Button (hidden by default) -->
    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/close_button"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_fab_close"
        android:src="@drawable/ic_close"
        android:contentDescription="@string/close_menu"
        android:visibility="gone"
        app:tint="@color/m3_sys_color_light_on_primary" />

    <!-- Main FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="@string/open_menu"
        android:src="@drawable/ic_add"
        app:fabSize="normal"
        app:backgroundTint="@color/m3_sys_color_light_primary"
        app:tint="@color/m3_sys_color_light_on_primary" />

</merge>
