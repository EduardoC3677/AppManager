{
  "$schema": "https://json.schemastore.org/mcp.json",
  "mcpServers": {
    "google-dev-docs": {
      "command": "npx",
      "args": ["-y", "@google/genai"],
      "env": {
        "GOOGLE_API_KEY": "${GEMINI_API_KEY}"
      },
      "description": "Google Developer Documentation MCP"
    },
    "material-design-3": {
      "command": "npx",
      "args": ["-y", "@lobehub/mcp-material-design-3"],
      "description": "Material Design 3 MCP"
    }
  }
}
